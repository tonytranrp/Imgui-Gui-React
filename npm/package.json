{
  "name": "igr-ui-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/react",
    "apps/react-native-test"
  ],
  "scripts": {
    "build:workspaces": "npm run build --workspaces --if-present",
    "build:menu": "node ../tests/menu/build-menu-assets.mjs",
    "build": "npm run build:workspaces && npm run build:menu",
    "export:fixtures": "node ./tools/export-fixtures.mjs",
    "hermes:bundle": "node ./tools/build-hermes-bundle.mjs",
    "test": "npm run build && npm run export:fixtures && node ./tools/run-tests.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3"
  }
}
